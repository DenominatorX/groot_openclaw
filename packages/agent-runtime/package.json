{
  "name": "@agentic/agent-runtime",
  "version": "0.1.0",
  "description": "Heartbeat scheduler and adapter runner for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "node --import tsx/esm --test 'src/**/*.test.ts'",
    "lint": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@agentic/core": "*",
    "drizzle-orm": "^0.38.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
