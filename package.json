{
  "name": "agentic-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic project management platform — automated task lifecycle, multi-agent coordination, and ethical governance tooling.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev": "npm run dev -w packages/api"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
